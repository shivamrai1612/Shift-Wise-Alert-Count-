PORT=4000
CORS_ORIGIN=http://localhost:5173

# Local dev — SQLite file persists data in data/shifts.db (recommended):
USE_MEMORY_DB=false
USE_SQLITE=true

# In-memory only (data lost on restart — not recommended):
# USE_MEMORY_DB=true

# Production / local PostgreSQL (set USE_MEMORY_DB=false):
# DATABASE_URL=postgresql://shiftuser:shiftpass@localhost:5432/shift_tracker
# DB_SSL=false
